        function generateGoals(probability) {
            const goals = [];
            const numGoals = Math.floor(Math.random() * 5);

            for (let i = 0; i < numGoals; i++) {
                if (Math.random() < probability) {
                    goals.push(generateScorer());
                }
            }
            return [...new Set(goals)];
        }


        function generateScorer() {
            const randomPosition = Math.random();
            const scorer = {};

            if (randomPosition < 0.6) {
                //60% -> Stürmer
                scorer.id = Math.floor(Math.random() * 3) + 9;
            } else if (randomPosition < 0.9) {
                //30% -> Mittelfeld
                scorer.id = Math.floor(Math.random() * 3) + 6;
            } else {
                //10% -> Verteidigung
                scorer.id = Math.floor(Math.random() * 4) + 2;
            }

            scorer.minute = Math.floor(Math.random() * 90) + 1;

            scorer.assist = generateAssist();

            return scorer;
        }

        function generateAssist(scorerId) {
            const randomPosition = Math.random();
            const assist = {};

            // Assign assisting player based on position probabilities
            if (randomPosition < 0.4) {
                // Forward (ids 9-11)
                assist.id = (scorerId === undefined || scorerId < 9 || scorerId > 11) ? Math.floor(Math.random() * 3) + 9 : Math.floor(Math.random() * 3) + 6;
            } else if (randomPosition < 0.8) {
                // Midfield (ids 6-8)
                assist.id = (scorerId === undefined || scorerId < 6 || scorerId > 8) ? Math.floor(Math.random() * 3) + 6 : Math.floor(Math.random() * 3) + 2;
            } else {
                // Defender (ids 2-5)
                assist.id = (scorerId === undefined || scorerId < 2 || scorerId > 5) ? Math.floor(Math.random() * 4) + 2 : Math.floor(Math.random() * 4) + 6;
            }

            return assist;
        }


