<script>
    $(document).ready(function () {
        let tabelle = '<%= encodeURIComponent(JSON.stringify(tabelle)) %>';
        tabelle = JSON.parse(decodeURIComponent(tabelle));
        let kalendar = '<%= encodeURIComponent(JSON.stringify(kalendar)) %>';
        kalendar = JSON.parse(decodeURIComponent(kalendar));
        let players = '<%= encodeURIComponent(JSON.stringify(players)) %>';
        players = JSON.parse(decodeURIComponent(players));
        let aufstellung = '<%= encodeURIComponent(JSON.stringify(aufstellung)) %>';
        aufstellung = JSON.parse(decodeURIComponent(aufstellung));
        let teams = '<%= encodeURIComponent(JSON.stringify(teams)) %>';
        teams = JSON.parse(decodeURIComponent(teams));
        let teamID = '<%= encodeURIComponent(JSON.stringify(teamID)) %>';
        teamID = JSON.parse(decodeURIComponent(teamID));
        let spieltag = '<%= encodeURIComponent(JSON.stringify(spieltag)) %>';
        spieltag = JSON.parse(decodeURIComponent(spieltag));
        let coins = '<%= encodeURIComponent(JSON.stringify(coins)) %>';
        coins = JSON.parse(decodeURIComponent(coins));

        $('.matchClose').on('click', function () {
            sendTable(tabelle);
            sendSpieltag();
            sendKalendar(kalendar);
            sendPlayers(players);
            sendCoins(coins);
            location.reload();
        });

        $('.showTeam').on('click', function () {
            const clickedId = $(this).attr('id');
            showTeamInfos(clickedId)
        });


        $("#select").on('click', function () {
            $(".spinner-border").show();
        });

        $(".overlap-group-4").on('click', function () {
            for (const x of kalendar) {
                if (x.intRound == spieltag) {
                    generateMatchResult(x.idEvent);
                }
            }
        });

        function generateMatchResult(idEvent) {
            let team1, team2, team1Kit, team2Kit;
            let team1Rating = 0;
            let team2Rating = 0;

            for (const x of kalendar) {
                if (x.idEvent === idEvent) {
                    if (x.idHomeTeam === teamID) {
                        team1 = x.idHomeTeam;
                        team2 = x.idAwayTeam;
                        for (const y of aufstellung) {
                            for (const z of players) {
                                if (z.idPlayer === y.idPlayer) team1Rating += z.intRating;
                            }
                        }
                        for (const y of teams) {
                            if (team2 === y.idTeam) {
                                for (const z of y.strLocked) {
                                    for (const a of players) {
                                        if (a.idPlayer === z.idPlayer) {
                                            team2Rating += a.intRating;
                                        }
                                    }
                                }
                            }
                        }
                    } else if (x.idAwayTeam === teamID) {
                        team1 = x.idAwayTeam;
                        team2 = x.idHomeTeam;
                        for (const y of aufstellung) {
                            for (const z of players) {
                                if (z.idPlayer === y.idPlayer) team1Rating += z.intRating;
                            }
                        }
                        for (const y of teams) {
                            if (team2 === y.idTeam) {
                                for (const z of y.strLocked) {
                                    for (const a of players) {
                                        if (a.idPlayer === z.idPlayer) {
                                            team2Rating += a.intRating;
                                        }
                                    }
                                }
                            }
                        }
                    } else {
                        team1 = x.idHomeTeam;
                        team2 = x.idAwayTeam;
                        for (const y of teams) {
                            if (team1 === y.idTeam) {
                                for (const z of y.strLocked) {
                                    for (const a of players) {
                                        if (a.idPlayer === z.idPlayer) {
                                            team1Rating += a.intRating;
                                        }
                                    }
                                }
                            }
                            if (team2 === y.idTeam) {
                                for (const z of y.strLocked) {
                                    for (const a of players) {
                                        if (a.idPlayer === z.idPlayer) {
                                            team2Rating += a.intRating;
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }

            if (team1Rating > team2Rating)
                team1Rating += 300;
            else if (team2Rating > team1Rating)
                team2Rating += 300;
            const totalRating = team1Rating + team2Rating;

            const team1Probability = team1Rating / totalRating;
            const team2Probability = team2Rating / totalRating;

            const team1Goals = generateGoals(team1Probability);
