<!DOCTYPE html>
<html lang="de">
<head>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-EVSTQN3/azprG1Anm3QDgpJLIm9Nao0Yz1ztcQTwFspd3yD65VohhpuuCOmLASjC" crossorigin="anonymous">
    <link rel="stylesheet" href="../css/index.css">
    <title>TacticX</title>
</head>
<body>
<div class="frame">
    <div class="div">
        <div class="links">
            <div class="overlap">
                <div class="links-bg"></div>
                <div class="sidebar">
                    <a class="marktplatz" draggable="false">
                        <img class="img" src="https://c.animaapp.com/buYDRGhc/img/marktplatz-icon.svg"/>
                        <div class="text-wrapper">Marktplatz</div>
                    </a>
                    <a class="verein" draggable="false">
                        <img class="img" src="https://c.animaapp.com/buYDRGhc/img/verein-icon.svg"/>
                        <div class="text-wrapper">Verein</div>
                    </a>
                    <a class="liga" draggable="false">
                        <img class="img" src="https://c.animaapp.com/buYDRGhc/img/liga-icon.svg"/>
                        <div class="text-wrapper">Liga</div>
                    </a>
                    <a class="dashboard" draggable="false">
                        <div class="overlap-group">
                            <img class="dashboard-icon" src="https://c.animaapp.com/buYDRGhc/img/dashboard-icon.png"/>
                            <div class="dashboard-text">Dashboard</div>
                        </div>
                    </a>
                </div>
                <div class="profile" draggable="false">
                    <div class="overlap-2">
                        <img class="logo" alt="logo" width="512" src="../assets/imgs/logo.png" draggable="false">
                        <div class="level">
                            <div class="level-text-wrapper">
                                <div class="level-text">TacticX</div>
                            </div>
                        </div>
                    </div>
                </div>
                <a class="einstellungen" href="einstellungen.html" draggable="false">
                    <div class="overlap-3">
                        <img class="einstellungen-icon"
                             src="https://c.animaapp.com/buYDRGhc/img/einstellungen-icon.svg"/>
                        <div class="einstellungen-text">Einstellungen</div>
                    </div>
                </a>
            </div>
        </div>
        <div class="modal fade" id="teamInfos" tabindex="-1" aria-labelledby="teamInfosLabel" aria-hidden="true">
            <div class="modal-dialog modal-lg">
                <div class="modal-content modal-bg">
                    <div class="modal-header">
                        <img id="teamInfos_badge" alt="logo" src="">
                        <h5 class="modal-title" id="teamInfosLabel"></h5>
                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"
                                aria-label="Close"></button>
                    </div>
                    <div class="modal-body">
                        <ul class="nav nav-tabs">
                            <li class="nav-item"><a class="nav-link active" data-bs-toggle="tab"
                                                    href="#spiele">Spiele</a></li>
                            <li class="nav-item"><a class="nav-link" data-bs-toggle="tab" href="#tabelle">Tabelle</a>
                            </li>
                            <li class="nav-item"><a class="nav-link" data-bs-toggle="tab"
                                                    href="#mannschaft">Mannschaft</a></li>
                        </ul>
                        <div class="tab-content">
                            <div class="tab-pane container active" id="spiele">
                                <div class="spiele"></div>
                            </div>
                            <div class="tab-pane container" id="tabelle">
                                <table class="tabelle"></table>
                            </div>
                            <div class="tab-pane container" id="mannschaft">
                                <div class="spieler">
                                    <div class="box" id="torwart"></div>
                                    <div class="box" id="verteidigung"></div>
                                    <div class="box" id="mittelfeld"></div>
                                    <div class="box" id="sturm"></div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <!-- Modal -->


        <div class="modal fade login " id="staticBackdrop" data-bs-backdrop="static" data-bs-keyboard="false"
             tabindex="-1" aria-labelledby="staticBackdropLabel">
            <div class="modal-dialog modal-fullscreen ">
                <div class="modal-content modal-bg">
                    <div class="modal-header">
                        <h1 class="modal-title" id="staticBackdropLabel">TacticX</h1>
                    </div>
                    <div class="login-body">
                        <form action="/selectTeam" method="post">
                            <div class="login-form">
                                <div class="form-group">
                                    <label for="ligaDropdown">Liga</label>
                                    <select class="form-control" id="ligaDropdown" name="ligaDropdown" required>
                                        <option value="">Ausw&auml;hlen</option>
                                        <option value="4328">GB | Premier League</option>
                                        <option value="4331">DE | Bundesliga</option>
                                        <option value="4335">ES | La Liga</option>
                                        <option value="4332">IT | Serie A</option>
                                        <option value="4334">FR | Ligue 1</option>
                                        <option value="4621">AT | Bundesliga</option>
                                    </select>
                                </div>
                                <div class="form-group" id="teamDropdownGroup" style="display:none;">
                                    <label for="teamDropdown">Team</label>
                                    <select class="form-control" id="teamDropdown" name="teamDropdown" required>
                                    </select>
                                </div>
                                <div class="form-check">
                                </div>
                                <button type="submit" class="btn btn-primary">Erstellen</button>
                            </div>
                            <div class="spinner-border" role="status"></div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
        <%
        if (teamID == null || leagueID == null) {
        %>
            <script>
                async function getTeamsInLeague(leagueID) {
                    const response = await fetch(`https://www.thesportsdb.com/api/v1/json/60130162/lookup_all_teams.php?id=${leagueID}`);
                    return response.json();
                }

                document.addEventListener('DOMContentLoaded', function () {
                    var modal = document.getElementById('staticBackdrop');
                    var modalInstance = new bootstrap.Modal(modal);
                    modalInstance.show();
                });

                document.getElementById('ligaDropdown').addEventListener('change', async function () {
                    if (this.value !== '') {
                        document.getElementById('teamDropdown').innerHTML = '<option value="">Ausw&auml;hlen</option>';
                        document.getElementById('teamDropdownGroup').style.display = 'block';

                        const data = await getTeamsInLeague(this.value);

                        // Clear the dropdown before adding new options
                        document.getElementById('teamDropdown').innerHTML = '<option value="">Ausw&auml;hlen</option>';

                        // Output the teams from the client-side variable
                        data.teams.forEach(function (team) {
                            const option = document.createElement('option');
                            option.value = team.idTeam;
                            option.text = team.strTeam;
                            document.getElementById('teamDropdown').add(option);
                        });
                    } else {
                        document.getElementById('teamDropdownGroup').style.display = 'none';
                    }
                });
            </script>
        <%
        }
        %>

        <div class="main">
            <div class="ergebnis-text">
                Ergebnisse
                <div class="ergebnisse">
                    <% for(const x of kalendar) {
                    if(x.intRound == spieltag - 1) {
                        let date, team1_badge, team2_badge, team1, team2
                        const inputDate = Date.parse(x.dateEvent)
                        let formattedDate = new Date(inputDate).toLocaleDateString('en-GB'); // Adjust the locale as needed
                        formattedDate = formattedDate.replace(/\//g, '.');

                        date = `${formattedDate}`;

                        teams.forEach(y => {
                            if (x.idHomeTeam === y.idTeam) {
                                team1_badge = y.strTeamBadge;
                                team1 = x.idHomeTeam
                            }
                            if (x.idAwayTeam === y.idTeam) {
                                team2_badge = y.strTeamBadge;
                                team2 = x.idAwayTeam
                            }
                        })
                    %>
                    <div class="ergebnis">
                        <div class="overlap-group-2">
                            <div class="text-wrapper-2">ENDSTAND</div>
                            <div class="datum"><%= date %></div>
                            <img class="ergebnis-team" src="<%= team2_badge %>" draggable="false"
                                 onclick="showTeamInfos(<%= team2 %>)">
                            <img class="ergebnis-team-2" src="<%= team1_badge %>" draggable="false"
                                 onclick="showTeamInfos(<%= team1 %>)">
                            <div class="ergebnis-text-wrapper">
                                <div class="text"><%= x.intHomeScore %> - <%= x.intAwayScore %></div>
                            </div>
                        </div>
                    </div>
                    <%
                    }
                    } %>
                </div>
            </div>
            <div class="userinfo">
                <div class="text-wrapper-3" id="username"><%= username %></div>
                <img class="ellipse"
                     src="data:image/png;base64,"
                     alt="profile" draggable="false">
            </div>

            <div class="matches" id="matches">
                <div class="matches-text">Deine Matches</div>
                <%
                let i = 0
                        for (const x of kalendar) {
                    let team1, team2, team1_badge, team2_badge, stadium, date, gegner;
                if ((x.idHomeTeam === teamID || x.idAwayTeam === teamID) && x.intRound == spieltag + i && i < 4) {
                    if (x.idHomeTeam === teamID) {
                        team1 = x.strHomeTeam;
                        team2 = x.strAwayTeam;
                    } else if (x.idAwayTeam === teamID) {
                        team1 = x.strAwayTeam;
                        team2 = x.strHomeTeam;
                    }
                    stadium = x.strVenue;

                    for (const y of teams) {
                        if (y.strTeam == team1) team1_badge = y.strTeamBadge;
                        if (y.strTeam == team2) team2_badge = y.strTeamBadge;
                    }

                    if (x.idHomeTeam != teamID)
                        gegner = x.idHomeTeam;
                    else gegner = x.idAwayTeam;

                    const inputDate = Date.parse(x.dateEvent)
                    let formattedDate = new Date(inputDate).toLocaleDateString('en-GB'); // Adjust the locale as needed
                    formattedDate = formattedDate.replace(/\//g, '.');
                    const parsedTime = Date.parse(`1970-01-01T${x.strTimeLocal}`);
                    const formattedTime = new Date(parsedTime).toLocaleTimeString('en-US', {
                        hour12: false,
                        hour: '2-digit',
                        minute: '2-digit'
                    });

                    date = `${formattedDate} | ${formattedTime}`;
                    const inMilliseconds = Date.parse(x.dateEvent) - Date.parse(datum);
                    let inDays = inMilliseconds / (24 * 60 * 60 * 1000);
                    inDays = Math.round(inDays)

                if (i >= 1) { %>
                    <div class="match">
                        <div class="info">
                            <div class="date"><%= date %></div>
                            <div class="stadium" id="match-stadium"><%= stadium %></div>
                            <div class="text-wrapper-6">VS</div>
                        </div>
                        <div class="gegner showTeam" id="<%= gegner %>">
                            <div class="gegner-text" id="match-team2"><%= team2 %></div>
                            <img class="icon" id="img2" src="<%= team2_badge %>" draggable="false">
                            <div class="type-wrapper">
                                <div class="type">Gegner</div>
                            </div>
                        </div>
                        <div class="team showTeam" id="<%= teamID %>">
                            <img class="img-2" id="match-img1" src="<%= team1_badge %>" draggable="false">
                            <div class="team-text" id="team1"><%= team1 %></div>
                            <div class="team-type-wrapper">
                                <div class="team-type">Dein Team</div>
                            </div>
                        </div>
                    </div>
                <% }
                    i++;
                }
                } %>
            </div>
            <div class="next-match" id="next-match">
                <div class="next-matches-text">N&auml;chstes Match</div>
                <%
                i = 0
                        for (const x of kalendar) {
                    let i = 0
                    let team1, team2, team1_badge, team2_badge, stadium, date, gegner;
                if ((x.idHomeTeam === teamID || x.idAwayTeam === teamID) && x.intRound == spieltag + i && i < 4) {
                    if (x.idHomeTeam === teamID) {
                        team1 = x.strHomeTeam;
                        team2 = x.strAwayTeam;
                    } else if (x.idAwayTeam === teamID) {
                        team1 = x.strAwayTeam;
                        team2 = x.strHomeTeam;
                    }
                    stadium = x.strVenue;

                    for (const y of teams) {
                        if (y.strTeam == team1) team1_badge = y.strTeamBadge;
                        if (y.strTeam == team2) team2_badge = y.strTeamBadge;
                    }

                    if (x.idHomeTeam != teamID)
                        gegner = x.idHomeTeam;
                    else gegner = x.idAwayTeam;

                    const inputDate = x.dateEvent.split("-");
                    const formattedDate = `${inputDate[2]}.${inputDate[1]}.${inputDate[0]}`;
                    const inputTime = x.strTimeLocal.split(":");
                    const formattedTime = `${inputTime[0]}:${inputTime[1]}`;
                    date = `${formattedDate} | ${formattedTime}`;
                    const inMilliseconds = Date.parse(x.dateEvent) - Date.parse(datum);
                    let inDays = inMilliseconds / (24 * 60 * 60 * 1000);
                    inDays = Math.round(inDays)

                if (i === 0) { %>
                    <div class="match-4">
                        <div class="gegner-4 showTeam" id="<%= gegner %>">
                            <div class="overlap-group-3">
                                <div class="type">Gegner</div>
                            </div>
                            <div class="gegner-text" id="match1-team2"><%= team2 %></div>
                            <img class="img-3" id="match1-img2"
                                 src="<%= team2_badge %>" draggable="false">
                        </div>
                        <div class="info-2">
                            <div class="info-date"><%= date %></div>
                            <div class="info-stadium" id="match1-stadium"><%= stadium %></div>
                            <div class="group-2">
                                <button class="overlap-group-4">
                                    <div class="text-wrapper-7"><%= inDays %> Tage</div>
                                </button>
                            </div>
                        </div>
                        <div class="team-2 showTeam" id="<%= teamID %>">
                            <img class="img-2" id="match1-img1"
                                 src="<%= team1_badge %>" draggable="false">
                            <div class="team-text" id="match1-team1"><%= team1 %></div>
                            <div class="team-type-wrapper">
                                <div class="team-type">Dein Team</div>
                            </div>
                        </div>
                    </div>
                <% }

                }
                } %>
            </div>
        </div>
    </div>
    <div class="spinner-border" role="status"></div>
</div>
<script src="https://code.jquery.com/jquery-3.4.1.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.0.0/dist/js/bootstrap.bundle.min.js"></script>
<script src="../js/index.js"></script>
<script>
    $(document).ready(function () {
        $('.showTeam').on('click', function () {
            const clickedId = $(this).attr('id');
            showTeamInfos(clickedId)
        });

        function showTeamInfos(teamId) {
            $(".tabelle").empty()
            $(".spiele").empty().scrollTop(0);
            $("#mannschaft").scrollTop(0);
            $("#torwart").empty();
            $("#verteidigung").empty();
            $("#mittelfeld").empty();
            $("#sturm").empty();
            let teams = '<%= encodeURIComponent(JSON.stringify(teams)) %>';
            teams = JSON.parse(decodeURIComponent(teams));

            let kalendar = '<%= encodeURIComponent(JSON.stringify(kalendar)) %>';
            kalendar = JSON.parse(decodeURIComponent(kalendar));

            let tabelle = '<%= encodeURIComponent(JSON.stringify(tabelle)) %>';
            tabelle = JSON.parse(decodeURIComponent(tabelle));

            let players = '<%= encodeURIComponent(JSON.stringify(players)) %>';
            players = JSON.parse(decodeURIComponent(players));

            let spieltag = '<%= spieltag %>';
            spieltag = parseInt(spieltag, 10);


            function decodeHTML(html) {
                var txt = document.createElement('textarea');
                txt.innerHTML = html;
                return txt.value;
            }

            teams.forEach(y => {
                if (y.idTeam == teamId) {
                    $("#teamInfosLabel").text(y.strTeam);
                    $("#teamInfos_badge").attr("src", y.strTeamBadge);
                    kalendar.forEach(x => {
                        let team1, team2, team1_badge, team2_badge, stadium, date, gegner;
                        if ((x.idHomeTeam === y.idTeam || x.idAwayTeam === y.idTeam) && x.intRound >= spieltag) {
                            if (x.idHomeTeam === y.idTeam) {
                                team1 = x.strHomeTeam;
                                team2 = x.strAwayTeam;
                            } else if (x.idAwayTeam === y.idTeam) {
                                team1 = x.strAwayTeam;
                                team2 = x.strHomeTeam;
                            }
                            stadium = x.strVenue;

                            teams.forEach(y => {
                                if (y.strTeam == team1) team1_badge = y.strTeamBadge;
                                if (y.strTeam == team2) team2_badge = y.strTeamBadge;
                            })


                            if (x.idHomeTeam != y.idTeam)
                                gegner = x.idHomeTeam;
                            else gegner = x.idAwayTeam;

                            const inputDate = x.dateEvent.split("-");
                            const formattedDate = `${inputDate[2]}.${inputDate[1]}.${inputDate[0]}`;
                            date = `${formattedDate}`;
                            $(".spiele").append(`
                    <div class="spiel">
                        <div class="spiel_info">
                            <div class="spiel_date">${date}</div>
                            <div class="spiel_vs">VS</div>
                        </div>
                        <div class="spiel_gegner">
                            <div class="spiel_gegner_text">${team2}</div>
                            <img class="spiel_gegner_badge" src="${team2_badge}" draggable="false">
                        </div>
                        <div class="spiel_team">
                            <img class="spiel_team_badge" src="${team1_badge}" draggable="false">
                            <div class="spiel_team_text">${team1}</div>
                        </div>
                    </div>
                `);
                        }
                    })
                    tabelle.sort((a, b) => {
                        if (a.intPunkte !== b.intPunkte) {
                            return b.intPunkte - a.intPunkte;
                        } else {
                            return b.intTordifferenz - a.intTordifferenz;
                        }
                    })
                    let i = 1;
                    tabelle.forEach(x => {
                        if (x.idTeam == teamId) {
                            $(".tabelle").append(`
                        <tr class="active showTeam" id=${x.idTeam}>
                            <td>${i}</td>
                            <td><img class="logo2" src="${x.strTeamBadge}" draggable="false">${x.strTeam}</td>
                            <td>${x.intSpiele}</td>
                            <td>${x.intSiege}</td>
                            <td>${x.intUnentschieden}</td>
                            <td>${x.intNiederlagen}</td>
                            <td>${x.intTore}</td>
                            <td>${x.intTordifferenz}</td>
                            <td>${x.intPunkte}</td>
                            <td>${x.strLetzteFuenf}</td>
                        </tr>
                    `)
                        } else {
                            $(".tabelle").append(`
                        <tr class="showTeam" id="${x.idTeam}">
                            <td>${i}</td>
                            <td><img class="logo2" src="${x.strTeamBadge}" draggable="false">${x.strTeam}</td>
                            <td>${x.intSpiele}</td>
                            <td>${x.intSiege}</td>
                            <td>${x.intUnentschieden}</td>
                            <td>${x.intNiederlagen}</td>
                            <td>${x.intTore}</td>
                            <td>${x.intTordifferenz}</td>
                            <td>${x.intPunkte}</td>
                            <td>${x.strLetzteFuenf}</td>
                        </tr>
                    `)
                        }
                        i++;
                    })
                    $(".tabelle").append(`
                <thead>
                    <tr>
                        <th>PL</th>
                        <th>Klub</th>
                        <th>SP</th>
                        <th>S</th>
                        <th>U</th>
                        <th>N</th>
                        <th>T</th>
                        <th>TD</th>
                        <th>PKT</th>
                        <th>Letzte 5</th>
                    </tr>
                </thead>
            `)

                }
            })
            players.forEach(x => {
                if (x.idTeam == teamId) {
                    let badge;

                    if (x.strCutout === null)
                        badge = "data:image/png;base64,"
                    else
                        badge = x.strCutout;
                    if (x.strPosition === "GK") {
                        $("#torwart").append(`
                    <div class="spielerbox">
                        <img class="pb" src="${badge}">
                        <div class="infobox">
                            <div class="pos">${x.strPosition}</div>
                            <div class="name">${x.strPlayer}</div>
                        </div>
                        <div class="rating">${x.intRating}</div>
                    </div>
                `)
                    } else if (x.strPosition.includes("B")) {
                        $("#verteidigung").append(`
                    <div class="spielerbox">
                        <img class="pb" src="${badge}">
                        <div class="infobox">
                            <div class="pos">${x.strPosition}</div>
                            <div class="name">${x.strPlayer}</div>
                        </div>
                        <div class="rating">${x.intRating}</div>
                    </div>
                `)
                    } else if (x.strPosition.includes("M")) {
                        $("#mittelfeld").append(`
                    <div class="spielerbox">
                        <img class="pb" src="${badge}">
                        <div class="infobox">
                            <div class="pos">${x.strPosition}</div>
                            <div class="name">${x.strPlayer}</div>
                        </div>
                        <div class="rating">${x.intRating}</div>
                    </div>
                `)
                    } else if (x.strPosition.includes("F") || x.strPosition.includes("W")) {
                        $("#sturm").append(`
                    <div class="spielerbox">
                        <img class="pb" src="${badge}">
                        <div class="infobox">
                            <div class="pos">${x.strPosition}</div>
                            <div class="name">${x.strPlayer}</div>
                        </div>
                        <div class="rating">${x.intRating}</div>
                    </div>
                `)
                    }
                }
            })
            $(".spinner-border").hide()
            $("#teamInfos").modal('show');
        }
    })
</script>
</body>
</html>