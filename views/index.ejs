            <script>
                async function getTeamsInLeague(leagueID) {
                    const response = await fetch(`https://www.thesportsdb.com/api/v1/json/60130162/lookup_all_teams.php?id=${leagueID}`);
                    return response.json();
                }

                document.addEventListener('DOMContentLoaded', function () {
                    var modal = document.getElementById('staticBackdrop');
                    var modalInstance = new bootstrap.Modal(modal);
                    modalInstance.show();
                });

                document.getElementById('ligaDropdown').addEventListener('change', async function () {
                    if (this.value !== '') {
                        document.getElementById('teamDropdown').innerHTML = '<option value="">Ausw&auml;hlen</option>';
                        document.getElementById('teamDropdownGroup').style.display = 'block';

                        const data = await getTeamsInLeague(this.value);

                        // Clear the dropdown before adding new options
                        document.getElementById('teamDropdown').innerHTML = '<option value="">Ausw&auml;hlen</option>';

                        // Output the teams from the client-side variable
                        data.teams.forEach(function (team) {
                            const option = document.createElement('option');
                            option.value = team.idTeam;
                            option.text = team.strTeam;
                            document.getElementById('teamDropdown').add(option);
                        });
                    } else {
                        document.getElementById('teamDropdownGroup').style.display = 'none';
                    }
                });
            </script>
