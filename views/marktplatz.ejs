<!DOCTYPE html>
<html lang="de">
<head>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/css/bootstrap.min.css" rel="stylesheet"
          integrity="sha384-EVSTQN3/azprG1Anm3QDgpJLIm9Nao0Yz1ztcQTwFspd3yD65VohhpuuCOmLASjC" crossorigin="anonymous">
    <link rel="stylesheet" href="../css/marktplatz.css">
    <title>Marktplatz</title>
</head>
<body>
<div class="frame">
    <div class="div">
        <div class="links">
            <div class="overlap">
                <div class="links-bg"></div>
                <div class="sidebar">
                    <a class="marktplatz" draggable="false">
                        <div class="overlap-group">
                            <img class="marktplatz-icon" src="https://c.animaapp.com/lC8erwo5/img/mdi-marketplace.svg"/>
                            <div class="marktplatz-text">Marktplatz</div>
                        </div>
                    </a>
                    <a class="verein" draggable="false">
                        <img class="img" src="https://c.animaapp.com/buYDRGhc/img/verein-icon.svg"/>
                        <div class="text-wrapper">Verein</div>
                    </a>
                    <a class="liga" draggable="false">
                        <img class="img" src="https://c.animaapp.com/buYDRGhc/img/liga-icon.svg"/>
                        <div class="text-wrapper">Liga</div>
                    </a>
                    <a class="dashboard" draggable="false">
                        <img class="dashboard-icon"
                             src="https://c.animaapp.com/WIUSBDf6/img/material-symbols-dashboard.svg"/>
                        <div class="dashboard-text">Dashboard</div>
                    </a>
                </div>
                <div class="profile" draggable="false">
                    <div class="overlap-2">
                        <img class="logo" alt="logo" width="512"
                             src="https://media.discordapp.net/attachments/1168601694670688397/1177183545630924810/Untitled-1-Recovered.png?ex=65967e9c&is=6584099c&hm=ec8262c9cdcee7d1f5db4ceb5a5bd3f5246355eb0fc7ddb9bd79fd9c6227b186&=&format=webp&quality=lossless&width=640&height=640"
                             draggable="false">
                        <div class="level">
                            <div class="level-text-wrapper">
                                <div class="level-text">TacticX</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="main">
            <div id="coins"><i class="fa-solid fa-coins"></i> <%= coins %></div>
            <div class="userinfo">
                <div class="text-wrapper-3" id="username"><%= username %></div>
                <img class="ellipse"
                     src="data:image/png;base64,"
                     alt="profile" draggable="false">
            </div>
            <div class="kauf-title">Spieler kaufen</div>
            <div class="kauf">
                <div class="row">
                    <%
                    for(const x of shop) {
                    if(x.typ === 0) {
                            for(const y of players) {
                    if(y.idPlayer === x.idPlayer) {
                    %>
                        <div class="col-sm-2">
                            <div class="card text-center" style="width: auto; border-radius: 20px">
                                <img class="card-img-top mx-auto" src="<%= y.strCutout %>"
                                     style="border-radius: 50%; width: 150px;" alt="Card image">
                                <div class=""
                                     style="position: absolute; width: 30px; height: 30px; background-color: #5f5fff; border-radius: 100%; top: 0; right: 20px; text-align: center; display: flex; align-items: center; justify-content: center;">
                                    <span style="color: white"><%= y.intRating %></span>
                                </div>
                                <div class="card-body d-flex flex-column align-items-center">
                                    <div class="card-title"><%= y.strPlayer %></div>
                                    <p class="card-text"><%= y.strPosition %><br><i
                                                class="fa-solid fa-coins"></i> <%= x.price %></p>
                                    <% if(y.idTeam === teamID){ %>
                                    <button onclick="buyPlayer('<%= y.idPlayer %>', <%= x.price %>)" disabled
                                            class="btn btn-primary mt-auto">Kaufen
                                    </button>
                                    <% }else{ %>
                                    <button onclick="buyPlayer('<%= y.idPlayer %>', <%= x.price %>)"
                                            class="btn btn-primary mt-auto">Kaufen
                                    </button>
                                    <% } %>
                                </div>
                            </div>
                        </div>
                    <%
                    }
                    }
                    }
                    }
                    %>
                </div>
            </div>
            <div class="verkauf-title">Spieler verkaufen</div>
            <div class="verkauf">
                <div class="row">
                    <%
                    for(const x of shop) {
                    if(x.typ === 1) {
                            for(const y of players) {
                    if(y.idPlayer === x.idPlayer) {
                    %>
                        <div class="col-sm-2">
                            <div class="card text-center" style="width: auto; border-radius: 20px">
                                <img class="card-img-top mx-auto" src="<%= y.strCutout %>"
                                     style="border-radius: 50%; width: 150px;" alt="Card image">
                                <div class=""
                                     style="position: absolute; width: 30px; height: 30px; background-color: #5f5fff; border-radius: 100%; top: 0; right: 20px; text-align: center; display: flex; align-items: center; justify-content: center;">
                                    <span style="color: white"><%= y.intRating %></span>
                                </div>
                                <div class="card-body d-flex flex-column align-items-center">
                                    <div class="card-title"><%= y.strPlayer %></div>
                                    <p class="card-text"><%= y.strPosition %><br><i
                                                class="fa-solid fa-coins"></i> <%= x.price %></p>
                                    <% if(y.idTeam === teamID){ %>
                                    <button onclick="sellPlayer('<%= y.idPlayer %>', <%= x.price %>)"
                                            class="btn btn-primary mt-auto">Verkaufen
                                    </button>
                                    <% }else{ %>
                                    <button onclick="sellPlayer('<%= y.idPlayer %>', <%= x.price %>)" disabled
                                            class="btn btn-primary mt-auto">Verkaufen
                                    </button>
                                    <% } %>
                                </div>
                            </div>
                        </div>
                    <%
                    }
                    }
                    }
                    }
                    %>
                </div>
            </div>
        </div>
    </div>
</div>
<script src='https://code.jquery.com/jquery-3.7.0.js'></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.0.0/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://kit.fontawesome.com/055b9b90fa.js" crossorigin="anonymous"></script>

<script src="../js/index.js"></script>

<script>
    let players = '<%= encodeURIComponent(JSON.stringify(players)) %>';
    players = JSON.parse(decodeURIComponent(players));
    let coins = '<%= encodeURIComponent(JSON.stringify(coins)) %>';
    coins = JSON.parse(decodeURIComponent(coins));
    let teamID = '<%= encodeURIComponent(JSON.stringify(teamID)) %>';
    teamID = JSON.parse(decodeURIComponent(teamID));
    let teams = '<%= encodeURIComponent(JSON.stringify(teams)) %>';
    teams = JSON.parse(decodeURIComponent(teams));

    let positions = {
        'GK': 1,
        'LB': 2,
        'CB': [3, 4],
        'RB': 5,
        'LM': 6,
        'CM': [6, 7, 8],
        'RM': 8,
        'RW': 11,
        'CF': 10,
        'LW': 9,
        'ST': [9, 10, 11]
    };


    function sendCoins(coins) {
        fetch('http://localhost:3000/updateCoins', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
            },
            body: JSON.stringify({coins: coins}), // Convert coins to a JSON string
        })
            .then(response => response.text())
            .then(data => {
                console.log('Response:', data);
            })
            .catch(error => {
                console.error('Error:', error);
            });
    }

    function sendPlayers(players) {

        fetch('http://localhost:3000/updatePlayers', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
            },
            body: JSON.stringify(players), // Send the formatted date
        })
            .then(response => response.text())
            .then(data => {
            })
            .catch(error => {
                console.error('Error:', error);
            });
    }

    function sendTeams(teams) {

        fetch('http://localhost:3000/updateTeams', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
            },
            body: JSON.stringify(teams),
        })
            .then(response => response.text())
            .then(data => {
            })
            .catch(error => {
                console.error('Error:', error);
            });
    }

    function buyPlayer(idPlayer, price) {
        if (coins >= price) {
            for (const x of players) {
                if (x.idPlayer === idPlayer) {
                    x.idTeam = teamID;
                    coins -= price;
                }
            }
            sendTeams(teams)
            sendCoins(coins)
            sendPlayers(players)
            location.reload();
        } else {
            alert("Du hast zu wenig Münzen")
        }

    }

    function sellPlayer(idPlayer, price) {
        let index = Math.floor(Math.random() * teams.length)
        while (teams[index].idTeam === teamID) {
            index = Math.floor(Math.random() * teams.length)
        }
        for (const x of players) {
            if (x.idPlayer === idPlayer) {
                x.idTeam = teams[index].idTeam;
                coins += price;
            }
        }
        sendTeams(teams)
        sendCoins(coins)
        sendPlayers(players)
        location.reload();
    }

</script>


</body>
</html>