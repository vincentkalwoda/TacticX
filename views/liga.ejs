<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8"/>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/css/bootstrap.min.css" rel="stylesheet"
          integrity="sha384-EVSTQN3/azprG1Anm3QDgpJLIm9Nao0Yz1ztcQTwFspd3yD65VohhpuuCOmLASjC" crossorigin="anonymous">
    <link rel="stylesheet" href="../css/liga.css"/>
</head>
<body>
<div class="frame">
    <div class="div">
        <div class="links">
            <div class="overlap">
                <div class="links-bg"></div>
                <div class="sidebar">
                    <a class="marktplatz" draggable="false">
                        <img class="img" src="https://c.animaapp.com/buYDRGhc/img/marktplatz-icon.svg"/>
                        <div class="text-wrapper">Marktplatz</div>
                    </a>
                    <a class="verein" draggable="false">
                        <img class="img" src="https://c.animaapp.com/buYDRGhc/img/verein-icon.svg"/>
                        <div class="text-wrapper">Verein</div>
                    </a>
                    <div class="div-wrapper">
                        <a class="group-4 liga" draggable="false">
                            <img class="img" src="https://c.animaapp.com/WIUSBDf6/img/ph-soccer-ball-fill.svg"/>
                            <div class="liga-text">Liga</div>
                        </a>
                    </div>
                    <a class="dashboard" draggable="false">
                        <img class="dashboard-icon"
                             src="https://c.animaapp.com/WIUSBDf6/img/material-symbols-dashboard.svg"/>
                        <div class="dashboard-text">Dashboard</div>
                    </a>
                </div>
                <div class="profile" draggable="false">
                    <div class="overlap-2">
                        <img class="logo" alt="logo" width="512"
                             src="https://media.discordapp.net/attachments/1168601694670688397/1177183545630924810/Untitled-1-Recovered.png?ex=65967e9c&is=6584099c&hm=ec8262c9cdcee7d1f5db4ceb5a5bd3f5246355eb0fc7ddb9bd79fd9c6227b186&=&format=webp&quality=lossless&width=640&height=640"
                             draggable="false">
                        <div class="level">
                            <div class="level-text-wrapper">
                                <div class="level-text">TacticX</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="group-9">
        <div id="coins"><i class="fa-solid fa-coins"></i> <%= coins %></div>
        <div class="text-wrapper-4">Kommende Spiele
            <div class="kommende-spiele">
                <%
                for(const x of kalendar) {
                if(x.intRound == spieltag) {
                    const inputDate = Date.parse(x.dateEvent)
                    let formattedDate = new Date(inputDate).toLocaleDateString('en-GB'); // Adjust the locale as needed
                    formattedDate = formattedDate.replace(/\//g, '.');

                    date = `${formattedDate}`;

                    let team1_badge, team2_badge
                    teams.forEach(y => {
                        if (x.idHomeTeam === y.idTeam) {
                            team1_badge = y.strTeamBadge;
                        }
                        if (x.idAwayTeam === y.idTeam) {
                            team2_badge = y.strTeamBadge;
                        }
                    })
                %>
                <div class="spiel">
                    <div class="overlap-group-23">
                        <div class="group-12">
                            <div class="text-wrapper-5">Spieltag <%= x.intRound %></div>
                            <div class="text-wrapper-6"><%= date %></div>
                        </div>
                        <div class="text-wrapper-7">VS</div>
                        <img class="image" src="<%= team1_badge %>"/>
                        <img class="image-2" src="<%= team2_badge %>"/>
                    </div>
                </div>
                <% }
                }
                %>

                </div>
        </div>

        <div class="userinfo">
            <div class="text-wrapper-3" id="username"><%= username %></div>
            <img class="ellipse"
                 src="data:image/png;base64,"
                 alt="profile" draggable="false">
        </div>
        <div class="group-19">
            <div class="text-wrapper-9">Tabelle</div>
            <div class="group-20">

                <table class="tabelle" id="tabelle">
                    <thead>
                    <tr>
                        <th>PL</th>
                        <th>Klub</th>
                        <th>SP</th>
                        <th>S</th>
                        <th>U</th>
                        <th>N</th>
                        <th>T</th>
                        <th>GT</th>
                        <th>TD</th>
                        <th>PKT</th>
                        <th>Letzte 5</th>
                    </tr>
                    </thead>

                    <%
                    for (const x of tabelle) {
                        x.intTordifferenz = x.intTore - x.intGegentore;
                    }
                    tabelle.sort((a, b) => {
                        if (a.intPunkte !== b.intPunkte) {
                            return b.intPunkte - a.intPunkte;
                        } else {
                            return b.intTordifferenz - a.intTordifferenz;
                        }
                    })
                    let i = 1;
                            for(const x of tabelle) {
                    %>
                        <tr>
                            <td><%= i %></td>
                            <td><img class="logo2" src="<%= x.strTeamBadge %>" draggable="false"><%= x.strTeam %></td>
                            <td><%= x.intSpiele %></td>
                            <td><%= x.intSiege %></td>
                            <td><%= x.intUnentschieden %></td>
                            <td><%= x.intNiederlagen %></td>
                            <td><%= x.intTore %></td>
                            <td><%= x.intGegentore %></td>
                            <td><%= x.intTordifferenz %></td>
                            <td><%= x.intPunkte %></td>
                            <td><%= x.strLetzteFuenf %></td>
                        </tr>
                    <%
                        i++;
                    }
                    %>
                </table>
            </div>
        </div>

        <div class="text-wrapper-10">Statistiken
            <div class="statistiken">
                <div class="overlap-group-wrapper">
                    <div class="overlap-3">
                        <div class="text-wrapper-27">Tore</div>
                        <div class="div-2">
                            <%
                            players.sort((a, b) => b.intGoals - a.intGoals);
                            for(let i = 0;i < 4;i++) {
                            if(players[i].intGoals !== 0) { %>
                            <div class="div-3">
                                <div class="text-wrapper-28"><%= players[i].strPlayer %></div>
                                <div class="overlap-group-2">
                                    <div class="text-wrapper-29"><%= players[i].intGoals %></div>
                                </div>
                            </div>
                            <%
                            }
                            }
                            %>

                        </div>
                    </div>
                </div>
                <div class="overlap-group-wrapper">
                    <div class="overlap-3">
                        <div class="text-wrapper-27">Vorlagen</div>
                        <div class="div-2">
                            <%
                            players.sort((a, b) => b.intAssists - a.intAssists);
                            for(let i = 0;i < 4;i++) {
                            if(players[i].intAssists !== 0) { %>
                            <div class="div-3">
                                <div class="text-wrapper-28"><%= players[i].strPlayer %></div>
                                <div class="overlap-group-2">
                                    <div class="text-wrapper-29"><%= players[i].intAssists %></div>
                                </div>
                            </div>
                            <%
                            }
                            }
                            %>
                        </div>
                    </div>
                </div>
                <div class="overlap-group-wrapper">
                    <div class="overlap-3">
                        <div class="text-wrapper-27">Tore + Vorlagen</div>
                        <div class="div-2">
                            <%
                            players.sort((a, b) => (b.intAssists + b.intGoals) - (a.intAssists + a.intGoals));
                            for (let i = 0; i < 4; i++) {
                            for(let i = 0;i < 4;i++) {
                            if((players[i].intGoals + players[i].intAssists) !== 0) {
                            %>
                            <div class="div-3">
                                <div class="text-wrapper-28"><%= players[i].strPlayer %></div>
                                <div class="overlap-group-2">
                                    <div class="text-wrapper-29"><%= (players[i].intGoals + players[i].intAssists) %></div>
                                </div>
                            </div>
                            <%
                            }}
                            }
                            %>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<%
if (teamID == null || leagueID == null) {
%>
    <script>location.href = '/dashboard'</script>

<%
}
%>

<script src='https://code.jquery.com/jquery-3.7.0.js'></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.0.0/dist/js/bootstrap.bundle.min.js"></script>
<script src='https://cdn.datatables.net/1.13.5/js/jquery.dataTables.min.js'></script>
<script src='https://cdn.datatables.net/responsive/2.1.0/js/dataTables.responsive.min.js'></script>
<script src='https://cdn.datatables.net/1.13.5/js/dataTables.bootstrap5.min.js'></script>
<script src="https://kit.fontawesome.com/055b9b90fa.js" crossorigin="anonymous"></script>

<script src="../js/index.js"></script>
</body>
</html>
